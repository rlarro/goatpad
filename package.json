{
  "name": "goatpad",
  "version": "0.1.0",
  "description": "A local markdown editor for clean round-trips with Claude. Built for long-form AI-assisted writing.",
  "main": "out/main/index.js",
  "author": "Rene Larro",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --mac --dir",
    "dist": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/search": "^6.5.8",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.1",
    "@lezer/markdown": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.renelarro.goatpad",
    "productName": "GoatPad",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.png",
      "target": [
        "dmg"
      ]
    }
  }
}
